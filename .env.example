# Provider OpenAI-compatible
# Qualquer provider que fale a API de chat completions da OpenAI funciona.

# --- OpenRouter (gratuito, sem cartão) ---
# Chave em: https://openrouter.ai/keys
DEVON_API_KEY=sk-or-sua-chave-aqui
DEVON_BASE_URL=https://openrouter.ai/api/v1
DEVON_MODEL=mistralai/devstral-2512:free

# --- Gemini (gratuito via AI Studio) ---
# Chave em: https://aistudio.google.com
# DEVON_API_KEY=AIzaSy-sua-chave-aqui
# DEVON_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# DEVON_MODEL=gemini-2.5-flash

# --- Ollama (local, sem chave) ---
# DEVON_BASE_URL=http://localhost:11434/v1
# DEVON_MODEL=qwen2.5-coder:32b

# --- Opções de comportamento ---
# DEVON_MODE=auto        # auto | safe | yolo
# DEVON_MAX_LOOPS=10     # máximo de iterações automáticas do loop do agente
# DEVON_TIMEOUT=30       # timeout por tool call em segundos
