{
  "name": "devon-vscode",
  "displayName": "Devon AI Agent",
  "description": "VS Code extension for Devon AI coding agent",
  "version": "0.1.0",
  "publisher": "devon",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devon.sendPrompt",
        "title": "Devon: Send Prompt"
      },
      {
        "command": "devon.interrupt",
        "title": "Devon: Interrupt"
      },
      {
        "command": "devon.resumeSession",
        "title": "Devon: Resume Session"
      },
      {
        "command": "devon.getStatus",
        "title": "Devon: Get Status"
      }
    ],
    "keybindings": [
      {
        "command": "devon.sendPrompt",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d"
      },
      {
        "command": "devon.interrupt",
        "key": "ctrl+shift+c",
        "mac": "cmd+shift+c"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "glob": "^10.3.10",
    "mocha": "^10.2.0",
    "@types/mocha": "^10.0.6",
    "vscode-test": "^1.6.1"
  }
}
