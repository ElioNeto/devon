# ============================================================
# .claudeignore — arquivos excluídos do contexto do Claude
# Sintaxe idêntica ao .gitignore
# ============================================================

# ------------------------------------------------------------
# Código legado Python/Node (pendente remoção pela issue #35)
# ------------------------------------------------------------
*.py
*.pyc
__pycache__/
test_*.py
package.json
bun.lock
tsconfig.json
start.sh
src/
scripts/
bin/

# ------------------------------------------------------------
# Dependências e build
# ------------------------------------------------------------
vendor/
node_modules/
dist/
build/
*.exe
*.test
*.out
coverage.out
coverage.html

# ------------------------------------------------------------
# Ambiente e segredos
# ------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.p12

# ------------------------------------------------------------
# Dados de runtime do Devon
# ------------------------------------------------------------
~/.devon/
*.db
*.sqlite
*.sqlite3
audit.log

# ------------------------------------------------------------
# Arquivos grandes ou binários
# ------------------------------------------------------------
*.lock
go.sum
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.ico
*.woff
*.woff2
*.ttf
*.eot

# ------------------------------------------------------------
# IDEs e sistema operacional
# ------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ------------------------------------------------------------
# Extensão VSCode (código TypeScript gerado/legado)
# ------------------------------------------------------------
vscode-extension/node_modules/
vscode-extension/out/
vscode-extension/dist/
vscode-extension/*.vsix
