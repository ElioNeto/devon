{
  "permissionMode": "auto",
  "allow": [
    "Bash(go build ./...)",
    "Bash(go test ./...)",
    "Bash(go test ./internal/...)",
    "Bash(go vet ./...)",
    "Bash(go mod tidy)",
    "Bash(go mod download)",
    "Bash(golangci-lint run)",
    "Bash(make build)",
    "Bash(make test)",
    "Bash(make lint)",
    "Bash(git status)",
    "Bash(git diff)",
    "Bash(git log --oneline*)",
    "Bash(git add *.go)",
    "Bash(git add *.md)",
    "Bash(ls*)",
    "Bash(cat*)",
    "Bash(grep*)",
    "Bash(find . -name '*.go'*)",
    "Read(**/*.go)",
    "Read(**/*.toml)",
    "Read(**/*.md)",
    "Read(**/*.json)",
    "Read(**/*.env.example)",
    "Read(.env.example)",
    "Write(**/*.go)",
    "Write(**/*.md)",
    "Write(docs/**)",
    "Write(internal/**)",
    "Write(cmd/**)"
  ],
  "deny": [
    "Bash(rm -rf /)",
    "Bash(rm -rf ~)",
    "Bash(chmod 777*)",
    "Bash(sudo*)",
    "Bash(curl * | bash)",
    "Bash(wget * | sh)",
    "Bash(> .env)",
    "Bash(dd *)",
    "Bash(mkfs*)",
    "Write(.env)",
    "Write(**/*.env)"
  ]
}
